# ─── Supabase (Auth + optional DB) ─────────────────────────────────────────
# Dashboard → Settings → API: use the Project URL and publishable (anon) key.
NEXT_PUBLIC_SUPABASE_URL=
# Prefer the publishable key (Dashboard label). Legacy anon key still works if set instead.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy name — if set without PUBLISHABLE_KEY, the app uses this.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the client. Used for admin operations if needed.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase CLI — optional OAuth secrets for `supabase/config.toml` + `npx supabase config push`
# (after `npx supabase login` and `npx supabase link --project-ref <your-ref>`). GitHub OAuth App
# callback on github.com must be https://<project-ref>.supabase.co/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Auth redirect URLs (must match Supabase Dashboard → Authentication → URL Configuration):
#   Site URL:     ${NEXT_PUBLIC_APP_URL}
#   Redirect:     ${NEXT_PUBLIC_APP_URL}/auth/callback
# Enable providers: Email, GitHub, Google under Authentication → Providers.
# GitHub: create a GitHub OAuth App (Developer settings). Authorization callback URL must be
#   https://<project-ref>.supabase.co/auth/v1/callback
#   (copy exact URL from Supabase → Authentication → Providers → GitHub). Homepage URL = your product URL.

# ─── GitHub App ────────────────────────────────────────────────────────────
# Create a GitHub App at https://github.com/settings/apps/new
#   Permissions: Contents (read), Metadata (read)
#   Events: push
#   Callback URL: use a dedicated path (e.g. ${NEXT_PUBLIC_APP_URL}/api/github/app/callback)
#   so it does not collide with Supabase Auth at ${NEXT_PUBLIC_APP_URL}/auth/callback
#   Setup URL:     ${NEXT_PUBLIC_APP_URL}/onboarding
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=autodsm
GITHUB_APP_WEBHOOK_SECRET=

# Optional — used as a fallback for public repos when no App install is present.
# Without this you're limited to 60 req/hr.
GITHUB_API_TOKEN=

# ─── AI ────────────────────────────────────────────────────────────────────
# Gemini 2.5 Flash-Lite is used for: one-shot component descriptions + render
# repair. Without this key the app still runs, just without AI assists.
GEMINI_API_KEY=

# ─── App ───────────────────────────────────────────────────────────────────
# Must be a full URL including scheme (https://…). A bare hostname (www.example.com)
# breaks OAuth: Supabase will treat it as a path on *.supabase.co.
NEXT_PUBLIC_APP_URL=http://localhost:3000
