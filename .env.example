# Set to "true" to seed demo tokens + components (no live GitHub parse).
# Only fills when autodsm:tokens and autodsm:components are both empty.
VITE_USE_DEMO_DATA=

# Supabase (optional, when you wire auth)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# GitHub OAuth (optional, if you self-manage OAuth) — server-only; do not use VITE_ prefix
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Server-only: raises GitHub API rate limits and enables private repo file reads for `/api/components/*`
GITHUB_TOKEN=

# Optional: max files fetched for component Sandpack graph (default 96, max 500)
COMPONENT_GRAPH_MAX_FILES=
