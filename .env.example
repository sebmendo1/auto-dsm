# ─── Supabase ──────────────────────────────────────────────────────────────
# Get URL + keys from Supabase Dashboard → Project Settings → API (do not commit real values here).
NEXT_PUBLIC_SUPABASE_URL=
# Newer Supabase projects use a "publishable" key. For older projects, use ANON.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: Vercel/Supabase integration sometimes sets these without NEXT_PUBLIC_;
# next.config bridges them into the browser bundle at build time.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── GitHub App ────────────────────────────────────────────────────────────
# Create a GitHub App at https://github.com/settings/apps/new
#   Permissions: Contents (read), Metadata (read)
#   Events: push
#   Callback URL:  ${NEXT_PUBLIC_APP_URL}/auth/callback
#   Setup URL:     ${NEXT_PUBLIC_APP_URL}/onboarding
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=autodsm
GITHUB_APP_WEBHOOK_SECRET=

# Optional — used as a fallback for public repos when no App install is present.
# Without this you're limited to 60 req/hr.
GITHUB_API_TOKEN=

# ─── AI ────────────────────────────────────────────────────────────────────
# Gemini 2.5 Flash-Lite is used for: one-shot component descriptions + render
# repair. Without this key the app still runs, just without AI assists.
GEMINI_API_KEY=

# ─── App ───────────────────────────────────────────────────────────────────
# No trailing slash. Local: http://localhost:3000
# Vercel (current canonical preview): https://autodsm.vercel.app — set in Project → Environment Variables.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# If 1, show onboarding preview on /login when not in development.
# NEXT_PUBLIC_ONBOARDING_DEV_PREVIEW=1

# Local only (never set in production): authenticated dashboard without login/Supabase scan.
# Add to .env.local — then open http://localhost:3000/dashboard
# DEV_AUTH_BYPASS=true
# Optional: change the fake repo slug shown in the UI (restart dev server after edits).
# DEV_PREVIEW_REPO=vercel/next.js
